---
// src/components/shared/Footer.astro
import Icon from './Icon.astro';
---
<footer class="bg-white border-t border-slate-100 pt-24 pb-32 font-urdu relative overflow-hidden">
    {/* Background Decorative Blob */}
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-emerald-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-16 text-right">
        
        {/* Left: Status */}
        <div class="space-y-6">
            <h4 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 opacity-60">System Status</h4>
            <div class="glass-premium p-8 rounded-[2.5rem] border border-white flex flex-col items-center gap-3 shadow-premium group hover:-translate-y-1 transition-all duration-500">
                <div class="flex items-center gap-3 text-emerald-500 font-black text-xl">
                    <div class="w-3 h-3 rounded-full bg-emerald-500 shadow-glow-emerald animate-pulse"></div>
                    <span>آن لائن (Active)</span>
                </div>
                <p class="text-[10px] text-slate-400 font-black uppercase tracking-widest opacity-60">All Servers Operational</p>
            </div>
        </div>

        {/* Center-Left: Quick Links */}
        <div class="space-y-6">
            <h4 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 opacity-60">Navigation</h4>
            <ul class="space-y-4">
                <li>
                    <a href="/" class="group flex items-center justify-end gap-3 text-slate-500 hover:text-emerald-500 transition-all font-black text-lg">
                        <span>ہوم پیج</span>
                        <div class="w-8 h-8 rounded-lg bg-slate-50 group-hover:bg-emerald-50 flex items-center justify-center transition-colors">
                            <Icon name="layout-dashboard" size={16} class="opacity-40 group-hover:opacity-100" />
                        </div>
                    </a>
                </li>
                <li>
                    <a href="/admin" class="group flex items-center justify-end gap-3 text-slate-500 hover:text-emerald-500 transition-all font-black text-lg">
                        <span>ایڈمن کنٹرول</span>
                        <div class="w-8 h-8 rounded-lg bg-slate-50 group-hover:bg-emerald-50 flex items-center justify-center transition-colors">
                            <Icon name="settings" size={16} class="opacity-40 group-hover:opacity-100" />
                        </div>
                    </a>
                </li>
            </ul>
        </div>

        {/* Center-Right: Socials (Optional/Future) */}
        <div class="space-y-6">
            <h4 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 opacity-60">Social Impact</h4>
            <div class="flex items-center justify-end gap-4">
               {[1,2,3,4].map(() => (
                   <div class="w-12 h-12 rounded-2xl bg-slate-50 border border-slate-100 flex items-center justify-center text-slate-300 hover:bg-emerald-500 hover:text-white transition-all cursor-pointer shadow-sm">
                       <Icon name="music" size={20} />
                   </div>
               ))}
            </div>
        </div>

        {/* Right: Brand Info */}
        <div class="space-y-8">
            <div class="flex items-center justify-end gap-6 text-right">
                <div class="relative">
                    <h2 class="text-4xl font-black text-slate-900 leading-tight">فکر <span class="text-emerald-500">اسلام</span></h2>
                    <p class="text-[8px] font-black text-emerald-600 uppercase tracking-[0.4em] mt-1 opacity-70">Authentic Guidance</p>
                </div>
                 <div class="relative">
                    <div class="absolute inset-0 bg-emerald-500/10 blur-xl rounded-full"></div>
                    <div class="relative w-20 h-20 rounded-[1.75rem] bg-white shadow-premium border border-white flex items-center justify-center p-3">
                        <img src="/logo.png" alt="Logo" class="w-full h-full object-contain" />
                    </div>
                 </div>
            </div>
            <p class="text-slate-400 text-base leading-relaxed max-w-sm ml-0 mr-auto font-bold opacity-80">
                مستند اسلامی کتب، خطبات اور ویڈیوز کا ایک جامع ذخیرہ — قابل اعتماد علماء سے ایک کلک پر۔
            </p>
        </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 mt-20 pt-10 border-t border-slate-50 flex flex-col md:flex-row items-center justify-between gap-6 opacity-40">
        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">© 2026 FIKR ISLAM — ALL RIGHTS RESERVED</p>
        <div class="flex items-center gap-6 text-[10px] font-black uppercase tracking-widest text-slate-400">
            <a href="#" class="hover:text-emerald-500 transition-colors">Privacy</a>
            <a href="#" class="hover:text-emerald-500 transition-colors">Terms</a>
        </div>
    </div>
</footer>

<style>
    footer {
        background-image: radial-gradient(circle at 50% -20%, rgba(16, 185, 129, 0.05), transparent 60%);
    }
</style>
