---
// src/components/shared/Navbar.astro
import Icon from './Icon.astro';
const navLinks = [
    { name: 'ہوم', href: '/' },
];
---

<header id="main-header" class="fixed top-0 left-0 right-0 z-[100] transition-all duration-700 bg-transparent py-4">
    <nav class="max-w-7xl mx-auto flex items-center justify-between h-16 md:h-20 glass-premium rounded-[2.5rem] shadow-premium px-2 group">
        {/* Logo */}
        <a href="/" class="flex items-center gap-4 group/logo px-4">
            <div class="relative w-12 h-12 flex items-center justify-center p-2 bg-white rounded-2xl shadow-md group-hover/logo:scale-110 transition-transform duration-500">
                 <img src="/logo.png" alt="Fikre Islam" class="w-full h-full object-contain" />
            </div>
            <div class="flex flex-col">
                <span class="text-xl font-black text-slate-900 tracking-tight font-urdu">
                    فکر اسلام
                </span>
                <span class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest leading-none">Official Portal</span>
            </div>
        </a>

        {/* Desktop Links */}
        <div class="hidden md:flex items-center gap-2 p-1.5 bg-slate-500/5 rounded-2xl mx-6">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class="group relative flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:text-emerald-600 hover:bg-white hover:shadow-sm transition-all duration-500"
                >
                    <span>{link.name}</span>
                </a>
            ))}
        </div>

        {/* Mobile Toggle */}
        <div class="flex items-center gap-4 px-4">
            <button
                id="mobile-menu-toggle"
                class="md:hidden w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-slate-100 text-slate-400 hover:text-emerald-500 shadow-sm transition-all"
                aria-label="Toggle menu"
            >
                <div id="menu-icon">
                    <Icon name="menu" size={24} />
                </div>
                <div id="close-icon" class="hidden">
                    <Icon name="x" size={24} />
                </div>
            </button>
        </div>
    </nav>

    {/* Mobile Menu with Enhanced Animation */}
    <div 
        id="mobile-menu" 
        class="hidden md:hidden absolute top-28 left-4 right-4 glass-premium rounded-[2rem] shadow-premium overflow-hidden border border-white/40 transition-all duration-500 transform scale-95 opacity-0"
    >
        <div class="p-4 flex flex-col gap-2">
            {navLinks.map((link) => (
                <a
                    href={link.href}
                    class="flex items-center justify-between px-6 py-4 rounded-2xl text-slate-700 bg-white/50 hover:bg-emerald-500 hover:text-white transition-all font-bold"
                >
                    <span>{link.name}</span>
                    <Icon name="chevron-left" size={16} />
                </a>
            ))}
        </div>
    </div>
</header>

<script>
    const header = document.getElementById('main-header');
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    // Scroll effect
    window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
            header?.classList.add('bg-white', 'shadow-lg', 'backdrop-blur-xl');
            header?.classList.remove('bg-transparent');
        } else {
            header?.classList.remove('bg-white', 'shadow-lg', 'backdrop-blur-xl');
            header?.classList.add('bg-transparent');
        }
    });

    // Mobile menu toggle
    toggle?.addEventListener('click', () => {
        const isOpen = !menu?.classList.contains('hidden');
        
        if (isOpen) {
            // Close
            menu?.classList.add('scale-y-0', 'opacity-0');
            setTimeout(() => menu?.classList.add('hidden'), 300);
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
        } else {
            // Open
            menu?.classList.remove('hidden');
            setTimeout(() => menu?.classList.remove('scale-y-0', 'opacity-0'), 10);
            menuIcon?.classList.add('hidden');
            closeIcon?.classList.remove('hidden');
        }
    });

    // Close menu on link click
    menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            menu?.classList.add('hidden');
            menuIcon?.classList.remove('hidden');
            closeIcon?.classList.add('hidden');
        });
    });
</script>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
    }
</style>
