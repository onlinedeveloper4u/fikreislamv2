---
// src/modules/admin/components/TaxonomyManager.astro
import { getDb } from '../../../lib/db';
import Icon from '../../../components/shared/Icon.astro';
import Modal from '../../../components/shared/Modal.astro';

interface Props {
    table: 'speakers' | 'categories' | 'languages' | 'audio_types';
    title: string;
    icon: string;
    placeholder: string;
    search?: string;
}

const { table, title, icon, placeholder, search = '' } = Astro.props;

// Fetch items server-side from MongoDB
const db = await getDb();
const filter: any = {};
if (search) {
    filter.name = { $regex: search, $options: 'i' };
}

const data = await db.collection(table)
    .find(filter)
    .sort({ name: 1 })
    .toArray();

// Map MongoDB _id to id for compatibility
const items = data.map((doc: any) => ({
    ...doc,
    id: doc._id.toString(),
}));
---

<div class="space-y-10 font-urdu pb-20">
    <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-8">
        <div class="flex items-center gap-6">
            <div class="w-16 h-16 rounded-[1.5rem] bg-emerald-500 flex items-center justify-center shadow-[0_15px_30px_-5px_rgba(16,185,129,0.3)] animate-glow shrink-0">
                <Icon name={icon} size={32} class="text-white" />
            </div>
            <div>
                <h1 class="text-3xl sm:text-4xl font-black text-slate-900 leading-tight">{title}</h1>
                <p class="text-xs text-emerald-600 font-black uppercase tracking-[0.2em] mt-2 opacity-80">ڈیٹا بیس ٹیکسونومی</p>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-4">
            <form method="GET" class="relative group w-full sm:w-auto">
                <div class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-emerald-500 transition-colors">
                    <Icon name="search" size={24} />
                </div>
                <input 
                    type="text"
                    name="search"
                    placeholder="تلاش کریں..."
                    value={search}
                    class="w-full sm:w-80 pr-14 pl-6 py-4 rounded-[1.75rem] bg-white border border-slate-100 focus:border-emerald-500 focus:bg-white transition-all shadow-sm outline-none font-black"
                />
            </form>
            <button 
                id="add-toggle-btn"
                class="w-full sm:w-auto flex items-center justify-center gap-3 px-10 py-4 bg-emerald-500 text-white rounded-[1.75rem] shadow-shadow-premium hover:bg-emerald-600 hover:-translate-y-1 active:scale-95 transition-all font-black"
            >
                <Icon name="plus" size={24} />
                <span>نیا شامل کریں</span>
            </button>
        </div>
    </div>

    {/* Add Modal */}
    <div id="taxonomy-modal" class="fixed inset-0 z-9999 hidden flex items-center justify-center px-4 py-8 md:py-20 pointer-events-none">
        <div id="taxonomy-modal-overlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md opacity-0 transition-opacity duration-500 pointer-events-auto"></div>
        <div id="taxonomy-modal-content" class="relative w-full max-w-lg mx-auto glass-premium rounded-[3rem] border border-white/40 shadow-2xl p-8 sm:p-12 opacity-0 scale-95 translate-y-8 transition-all duration-500 pointer-events-auto">
            {/* Close Button */}
            <button 
                type="button"
                class="close-modal-btn absolute left-8 top-8 w-12 h-12 flex items-center justify-center bg-white/80 border border-slate-100 rounded-2xl text-slate-400 hover:text-red-500 hover:bg-white hover:shadow-premium transition-all z-20 pointer-events-auto"
                title="بند کریں"
            >
                <Icon name="x" size={24} />
            </button>

            <div class="flex items-center gap-6 mb-8 mt-4">
                <div class="w-16 h-16 rounded-3xl bg-emerald-500 flex items-center justify-center shadow-glow-emerald shrink-0">
                    <Icon name={icon} size={32} class="text-white" />
                </div>
                <div>
                    <h2 class="text-3xl font-black text-slate-900">جدید {title}</h2>
                    <p class="text-[10px] text-emerald-600 font-black uppercase tracking-widest mt-1 opacity-80">ڈیٹا بیس میں شامل کریں</p>
                </div>
            </div>
            
            <div class="space-y-8">
                <div>
                    <label class="block text-xs font-black text-slate-400 mb-2 uppercase tracking-widest mr-4">نام درج کریں</label>
                    <input 
                        type="text"
                        id="new-item-name"
                        placeholder={placeholder}
                        class="w-full px-8 py-5 rounded-2xl bg-white border border-slate-100 focus:border-emerald-500 transition-all outline-none font-black text-xl shadow-sm"
                    />
                </div>
                <div class="flex items-center gap-4">
                    <button id="save-btn" class="flex-1 flex items-center justify-center gap-4 px-10 py-5 bg-emerald-500 text-white rounded-2xl hover:bg-emerald-600 transition-all shadow-shadow-premium font-black group">
                        <Icon name="check" size={24} class="group-hover:scale-110 transition-transform" />
                        <span>محفوظ کریں</span>
                    </button>
                    <button id="cancel-btn" class="px-8 py-5 bg-white border border-slate-100 text-slate-400 rounded-2xl hover:text-red-500 transition-all font-black shadow-sm">
                        کینسل
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
        {items.length === 0 ? (
            <div class="col-span-full py-40 text-center glass-premium rounded-[3rem] border-2 border-dashed border-slate-200">
                <div class="flex flex-col items-center gap-6 opacity-30">
                    <div class="w-32 h-32 rounded-full bg-slate-50 flex items-center justify-center">
                        <Icon name={icon} size={64} class="text-slate-200" />
                    </div>
                    <div>
                        <p class="text-2xl font-black text-slate-400 uppercase tracking-widest">کوئی ریکارڈ نہیں ملا</p>
                        <p class="text-slate-300 mt-2 font-bold">براہ کرم تلاش کا لفظ تبدیل کریں</p>
                    </div>
                </div>
            </div>
        ) : items.map((item: any) => (
            <div class="glass-premium p-6 border border-white/40 rounded-[2.5rem] flex items-center justify-between group hover:border-emerald-500/30 shadow-premium transition-all duration-500 hover:-translate-y-2 relative overflow-hidden">
                <div class="absolute -top-12 -left-12 w-24 h-24 bg-emerald-500/5 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                
                <div class="flex items-center gap-5 relative z-10">
                    <div class="w-16 h-16 rounded-[1.25rem] bg-white flex items-center justify-center text-slate-300 group-hover:bg-emerald-500 group-hover:text-white border border-slate-100 shadow-sm group-hover:shadow-glow-emerald transition-all duration-500">
                        <Icon name={icon} size={28} />
                    </div>
                    <div>
                        <div class="font-black text-slate-900 text-xl group-hover:text-emerald-600 transition-colors uppercase tracking-tight leading-tight">{item.name}</div>
                        <div class="flex items-center gap-2 mt-2">
                            <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-glow-emerald animate-pulse"></span>
                            <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest opacity-60">آئی ڈی: {String(item.id).slice(0, 8)}</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-2 relative z-10">
                    <button class="w-12 h-12 rounded-2xl bg-white border border-slate-100 text-slate-400 hover:bg-red-500 hover:text-white hover:border-red-500 hover:shadow-premium hover:-translate-y-1 transition-all duration-300 flex items-center justify-center delete-btn" data-id={item.id} data-name={item.name} title="حذف کریں">
                        <Icon name="trash" size={20} />
                    </button>
                </div>
            </div>
        ))}
    </div>
    
    <Modal 
        id="delete-confirm" 
        title="مواد حذف کریں" 
        description="کیا آپ واقعی اسے حذف کرنا چاہتے ہیں؟ یہ عمل واپس نہیں لیا جا سکتا۔"
        confirmText="ہاں، حذف کریں"
        cancelText="واپس جائیں"
        type="danger"
    />
</div>

<script define:vars={{ table }}>
    function initTaxonomyActions() {
        const addToggleBtn = document.getElementById('add-toggle-btn');
        const modal = document.getElementById('taxonomy-modal');
        const overlay = document.getElementById('taxonomy-modal-overlay');
        const content = document.getElementById('taxonomy-modal-content');
        const cancelBtn = document.getElementById('cancel-btn');
        const saveBtn = document.getElementById('save-btn');
        const newItemInput = document.getElementById('new-item-name');

        function toggleModal(show) {
            if (show) {
                if (modal && modal.parentElement !== document.body) {
                    document.body.appendChild(modal);
                }
                if (window.toggleBodyScroll) window.toggleBodyScroll(true);
                modal?.classList.remove('hidden');
                setTimeout(() => {
                    overlay?.classList.add('opacity-100');
                    content?.classList.add('opacity-100', 'translate-y-0', 'scale-100');
                    content?.classList.remove('translate-y-8', 'scale-95');
                    newItemInput?.focus();
                }, 10);
            } else {
                overlay?.classList.remove('opacity-100');
                content?.classList.remove('opacity-100', 'translate-y-0', 'scale-100');
                content?.classList.add('translate-y-8', 'scale-95');
                setTimeout(() => {
                    modal?.classList.add('hidden');
                    if (newItemInput) newItemInput.value = '';
                    if (window.toggleBodyScroll) window.toggleBodyScroll(false);
                }, 500);
            }
        }

        if (addToggleBtn && !addToggleBtn._initialized) {
            addToggleBtn._initialized = true;
            addToggleBtn.addEventListener('click', () => toggleModal(true));
        }

        document.querySelectorAll('.close-modal-btn').forEach(btn => {
            if (btn._initialized) return;
            btn._initialized = true;
            btn.addEventListener('click', () => toggleModal(false));
            overlay?.addEventListener('click', () => toggleModal(false));
        });

        if (cancelBtn && !cancelBtn._initialized) {
            cancelBtn._initialized = true;
            cancelBtn.addEventListener('click', () => toggleModal(false));
        }

        if (saveBtn && !saveBtn._initialized) {
            saveBtn._initialized = true;
            saveBtn.addEventListener('click', async () => {
                const name = newItemInput?.value?.trim();
                if (!name) return;

                saveBtn.disabled = true;
                const origText = saveBtn.innerHTML;
                saveBtn.innerHTML = '<span class="animate-pulse">محفوظ ہو رہا ہے...</span>';

                try {
                    const response = await fetch('/api/admin/taxonomy', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'add', table, name })
                    });

                    if (response.ok) {
                        if (window.showToast) window.showToast("کامیابی سے شامل کر دیا گیا۔", "success");
                        toggleModal(false);
                        setTimeout(() => window.location.reload(), 500);
                    } else {
                        if (window.showToast) window.showToast("شامل کرنے میں خرابی۔", "error");
                        saveBtn.disabled = false;
                        saveBtn.innerHTML = origText;
                    }
                } catch (err) {
                    if (window.showToast) window.showToast("سسٹم میں خرابی۔", "error");
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = origText;
                }
            });
        }

        // Delete logic
        document.querySelectorAll('.delete-btn').forEach(btn => {
            if (btn._initialized) return;
            btn._initialized = true;
            btn.addEventListener('click', async () => {
                const id = btn.getAttribute('data-id');

                if (window.showModal_delete_confirm) {
                    window.showModal_delete_confirm(async (confirmed) => {
                        if (!confirmed) return;
                        
                        try {
                            const response = await fetch('/api/admin/taxonomy', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ action: 'delete', table, id })
                            });

                            if (response.ok) {
                                if (window.showToast) window.showToast("کامیابی سے حذف کر دیا گیا۔", "success");
                                setTimeout(() => window.location.reload(), 500);
                            } else {
                                if (window.toast) window.toast.show("حذف کرنے میں خرابی۔", "error");
                                else if (window.showToast) window.showToast("حذف کرنے میں خرابی۔", "error");
                            }
                        } catch (err) {
                            if (window.toast) window.toast.show("سسٹم میں خرابی۔", "error");
                            else if (window.showToast) window.showToast("سسٹم میں خرابی۔", "error");
                        }
                    });
                } else {
                    console.error("Delete confirmation modal function purely not found!");
                }
            });
        });
    }

    initTaxonomyActions();
    if (!window._taxonomyScriptAttached) {
        window._taxonomyScriptAttached = true;
        document.addEventListener('astro:page-load', initTaxonomyActions);
    }
</script>
