---
// src/modules/home/components/AudioCard.astro
import type { ContentItem } from '../../../lib/types';
import Icon from '../../../components/shared/Icon.astro';

interface Props {
  item: ContentItem;
  view?: 'grid' | 'list';
}

const { item, view = 'grid' } = Astro.props;

// Format duration
const formatDur = (dur: string | number | undefined) => {
    if (!dur) return '00:00';
    if (typeof dur === 'string' && dur.includes(':')) return dur;
    const d = Number(dur);
    const m = Math.floor(d / 60);
    const s = Math.floor(d % 60);
    return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
};

const dateStr = item.lecture_date_gregorian ? new Date(item.lecture_date_gregorian).getFullYear() : '2026';
const fullDate = item.lecture_date_gregorian ? new Date(item.lecture_date_gregorian).toLocaleDateString('en-GB') : '04/03/2026';
---

{view === 'grid' ? (
    <div 
        class="audio-card-grid glass-card group overflow-hidden flex flex-col h-full animate-fade-in rounded-[2rem] border border-slate-100/50 hover:border-emerald-500/30 transition-all duration-500 shadow-xl shadow-slate-200/50 hover:-translate-y-2 searchable-item"
        data-search-term={`${item.title} ${item.speaker} ${item.description || ''} ${item.audio_type || ''} ${item.language || ''}`.toLowerCase()}
    >
        {/* Top Image Area */}
        <div class="relative aspect-square overflow-hidden bg-slate-100 rounded-[1.8rem] m-2">
            {item.cover_image_url ? (
                <img src={item.cover_image_url} alt={item.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-slate-800 to-black text-white">
                    <Icon name="music" size={64} class="opacity-20" />
                </div>
            )}
            
            {/* Badges */}
            {item.language && (
                <div class="absolute top-4 right-4 z-10">
                    <span class="px-4 py-1.5 bg-emerald-500/90 backdrop-blur-md text-white text-[10px] font-black rounded-xl shadow-lg uppercase tracking-widest">
                        {item.language}
                    </span>
                </div>
            )}

            {/* Play Button Overlay */}
            <div class="absolute inset-0 flex items-center justify-center z-20">
                <button 
                   class="play-btn w-16 h-16 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-2xl transform scale-90 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-500 hover:bg-emerald-600 active:scale-95"
                   data-audio-url={item.file_url}
                   data-title={item.title}
                   data-author={item.speaker}
                >
                    <Icon name="play" size={32} class="animate-pulse-slow" />
                </button>
            </div>

            {/* Bottom Meta Bar */}
            <div class="absolute bottom-0 left-0 right-0 bg-black/40 backdrop-blur-md px-5 py-3 flex items-center justify-between text-[11px] font-black text-white/90 ltr">
                <div class="flex items-center gap-2">
                    <Icon name="calendar" size={12} class="text-emerald-400" />
                    <span>{dateStr}</span>
                </div>
                <div class="flex items-center gap-2">
                    <span>{formatDur(item.duration || '00:00')}</span>
                    <Icon name="clock" size={12} class="text-emerald-400" />
                </div>
            </div>
        </div>

        {/* Content */}
        <div class="p-6 flex flex-col gap-5 text-center flex-1">
            <h3 class="font-urdu text-xl font-bold text-slate-900 line-clamp-2 leading-relaxed group-hover:text-emerald-600 transition-colors">
                {item.title}
            </h3>
            
            <div class="mt-auto">
                <button class="w-full py-4 bg-slate-50/50 rounded-2xl border border-slate-100 flex items-center justify-center gap-3 text-slate-500 group-hover:bg-emerald-50 group-hover:border-emerald-200 transition-all duration-300">
                    <Icon name="download" size={18} class="group-hover:text-emerald-600 transition-colors" />
                    <span class="text-xs font-black text-slate-600 group-hover:text-emerald-700">{item.file_size || '9.8MB'}</span>
                </button>
            </div>
        </div>
    </div>
) : (
    <div 
        class="audio-card-list glass-card group overflow-hidden flex items-center gap-8 p-5 animate-fade-in rounded-[2.5rem] border border-slate-100/50 hover:border-emerald-500/30 transition-all duration-500 shadow-lg shadow-slate-200/40 w-full relative hover:shadow-premium searchable-item"
        data-search-term={`${item.title} ${item.speaker} ${item.description || ''} ${item.audio_type || ''} ${item.language || ''}`.toLowerCase()}
    >
        {/* Left Side: Badge */}
        <div class="shrink-0 hidden sm:block">
             <span class="px-4 py-2 bg-white border border-emerald-100 text-emerald-600 text-[10px] font-black rounded-xl uppercase tracking-widest shadow-sm">
                {item.language || 'Urdu'}
             </span>
        </div>

        {/* Main Info */}
        <div class="flex-1 flex flex-col gap-2 items-end pr-8">
            <h3 class="font-urdu text-2xl font-bold text-slate-900 group-hover:text-emerald-600 transition-colors leading-tight">
                {item.title}
            </h3>
            <div class="flex items-center gap-6 text-slate-400 font-black text-[11px] ltr uppercase tracking-widest opacity-60">
                <div class="flex items-center gap-2">
                    <Icon name="calendar" size={14} class="text-emerald-500" />
                    <span>{fullDate}</span>
                </div>
                <div class="flex items-center gap-2">
                    <Icon name="clock" size={14} class="text-emerald-500" />
                    <span>{formatDur(item.duration || '00:00')}</span>
                </div>
            </div>
        </div>

        {/* Controls */}
        <div class="flex items-center gap-5">
            <button class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 hover:bg-emerald-50 hover:text-emerald-600 transition-all border border-slate-100 hover:border-emerald-200 group/down">
                <div class="flex flex-col items-center gap-0.5">
                    <Icon name="download" size={20} class="group-hover/down:-translate-y-0.5 transition-transform" />
                    <span class="text-[8px] font-black whitespace-nowrap opacity-60">{item.file_size || '9MB'}</span>
                </div>
            </button>
            <button 
                class="play-btn w-14 h-14 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-lg hover:bg-emerald-600 hover:scale-110 active:scale-95 transition-all duration-300"
                data-audio-url={item.file_url}
                data-title={item.title}
                data-author={item.speaker}
            >
                <Icon name="play" size={28} />
            </button>
        </div>

        {/* Right Side: Small Image */}
        <div class="w-24 h-24 rounded-[1.75rem] overflow-hidden shrink-0 shadow-premium border-2 border-white group-hover:rotate-2 transition-transform duration-500">
             {item.cover_image_url ? (
                <img src={item.cover_image_url} alt="" class="w-full h-full object-cover" />
            ) : (
                <div class="w-full h-full flex items-center justify-center bg-slate-900 text-white/20">
                    <Icon name="music" size={40} />
                </div>
            )}
        </div>
    </div>
)}

<script>
    function initButtons() {
        document.querySelectorAll('.play-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const btnEl = e.currentTarget as HTMLElement;
                const detail = {
                    url: btnEl.getAttribute('data-audio-url'),
                    title: btnEl.getAttribute('data-title'),
                    author: btnEl.getAttribute('data-author')
                };
                
                document.dispatchEvent(new CustomEvent('play-audio', { detail }));
            });
        });
    }

    initButtons();
    document.addEventListener('astro:page-load', initButtons);
</script>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(20px);
    }
</style>
