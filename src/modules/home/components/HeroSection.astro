---
// src/modules/home/components/HeroSection.astro
import Icon from '../../../components/shared/Icon.astro';
---

<section class="relative min-h-[95vh] flex items-center overflow-hidden pt-24 pb-20">
    {/* Background Pattern */}
    <div class="absolute inset-0 bg-[#fafafa]">
        <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');"></div>
    </div>

    {/* Dynamic Background Elements */}
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-emerald-100/40 rounded-full blur-[120px] pointer-events-none animate-blob"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[600px] h-[600px] bg-teal-100/30 rounded-full blur-[120px] pointer-events-none animate-blob animation-delay-2000"></div>
    <div class="absolute top-[20%] left-[20%] w-[300px] h-[300px] bg-emerald-500/5 rounded-full blur-[80px] pointer-events-none animate-blob animation-delay-4000"></div>

    <div class="container-app relative z-10">
        <div class="max-w-5xl mx-auto text-center space-y-10">
            {/* Logo Mark with Premium Glow */}
            <div class="animate-float relative inline-block">
                <div class="absolute inset-0 bg-emerald-500/20 blur-[50px] rounded-full"></div>
                <div class="relative w-36 h-36 sm:w-48 sm:h-48 mx-auto flex items-center justify-center p-4">
                    <img src="/logo.png" alt="Fikre Islam" class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(16,185,129,0.3)]" />
                </div>
            </div>

            {/* Premium Badge */}
            <div class="animate-fade-in-up">
                <span class="inline-flex items-center gap-2.5 px-6 py-2.5 rounded-full bg-white shadow-xl shadow-emerald-500/5 border border-emerald-500/10 text-emerald-600 text-xs font-black uppercase tracking-[0.2em]">
                    <Icon name="shield-check" size={14} />
                    مستند اسلامی مواد
                </span>
            </div>

            {/* Main Heading with Layered Text Shadows */}
            <div class="animate-fade-in-up delay-100">
                <h1 class="font-urdu text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black text-slate-900 leading-[1.1] tracking-tight">
                    فکر <span class="text-emerald-500 text-glow-emerald">اسلام</span>
                </h1>
            </div>

            {/* Description with Better Contrast */}
            <p class="text-lg md:text-2xl text-slate-500/80 max-w-3xl mx-auto leading-relaxed animate-fade-in-up delay-200 font-bold opacity-90">
                مختلف علماء کے بصیرت افروز خطبات، سلسلے اور قرآنی تلاوت سنیں — ایک کلک پر مستند اسلامی رہنمائی۔
            </p>

            {/* Premium CTA with Interaction */}
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 animate-fade-in-up delay-300">
                <a
                    href="#audio-library"
                    class="group relative inline-flex items-center gap-4 px-12 py-5 rounded-[2rem] bg-emerald-500 text-white font-black text-xl shadow-[0_20px_50px_-10px_rgba(16,185,129,0.5)] hover:shadow-[0_25px_60px_-10px_rgba(16,185,129,0.6)] hover:-translate-y-1 transition-all duration-500 overflow-hidden"
                >
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                    <span>لائبریری دیکھیں</span>
                    <Icon name="chevron-left" size={24} class="group-hover:-translate-x-2 transition-transform duration-500" />
                </a>
            </div>
        </div>
    </div>

    {/* Scroll Indicator */}
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20 hidden md:block">
        <Icon name="mouse" size={32} />
    </div>
</section>

<style>
    .animate-float {
        animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
    .animate-pulse-slow {
        animation: pulse-slow 8s ease-in-out infinite;
    }
    @keyframes pulse-slow {
        0%, 100% { transform: scale(1); opacity: 0.15; }
        50% { transform: scale(1.3); opacity: 0.3; }
    }
    .animate-pulse-delayed {
        animation: pulse-slow 12s ease-in-out infinite;
        animation-delay: 2s;
    }
    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
</style>
