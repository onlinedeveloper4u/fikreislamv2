---
// src/modules/auth/components/ForgotPasswordForm.astro
import Icon from '../../../components/shared/Icon.astro';
import ResetSuccess from './ResetSuccess.astro';
---

<div class="relative w-full max-w-md mx-auto">
    <div id="form-container" class="animate-fade-in-up">
        <div class="bg-white rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] p-10 md:p-14 text-center relative overflow-hidden">
            {/* Logo Section */}
            <div class="mb-10 relative z-10 transition-transform duration-500 hover:scale-110">
                <div class="w-28 h-28 mx-auto rounded-full overflow-hidden">
                    <img src="/logo.png" alt="فکر اسلام لوگو" class="w-full h-full object-contain" />
                </div>
                <div class="mt-8 space-y-2">
                    <h1 class="text-4xl font-black text-emerald-800 font-urdu leading-tight">فکرِ اسلام</h1>
                    <h2 class="text-2xl font-bold text-slate-700 font-urdu">پاس ورڈ بھول گئے؟</h2>
                    <p class="text-slate-400 font-bold text-sm font-urdu opacity-80">اپنا رجسٹرڈ ای میل ایڈریس درج کریں</p>
                </div>
            </div>

            <form id="forgot-password-form" class="space-y-8 relative z-10 text-right" dir="rtl">
                <div class="space-y-2">
                    <label class="block text-sm font-bold text-slate-500 mr-2 font-urdu">ای میل</label>
                    <div class="relative group">
                        <input 
                            type="email" 
                            name="email"
                            required
                            class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-emerald-500 focus:bg-white shadow-sm transition-all outline-none font-bold text-slate-700 pr-14"
                            placeholder="اپنی ای میل درج کریں"
                        />
                        <div class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-emerald-600 group-focus-within:scale-110 transition-all">
                            <Icon name="at-sign" size={20} />
                        </div>
                    </div>
                </div>

                <button 
                    type="submit" 
                    id="submit-btn"
                    class="w-full py-5 rounded-2xl bg-[#1a6336] text-white font-black text-xl shadow-lg shadow-emerald-900/10 hover:bg-[#14532d] hover:-translate-y-1 active:scale-95 transition-all flex items-center justify-center gap-4 group"
                >
                    <span id="btn-text" class="font-urdu">ری سیٹ لنک بھیجیں</span>
                    <div id="btn-icon" class="transition-transform group-hover:translate-x-1">
                        <Icon name="chevron-left" size={24} />
                    </div>
                    <div id="btn-loader" class="hidden">
                         <div class="w-6 h-6 border-4 border-white/30 border-t-white rounded-full animate-spin"></div>
                    </div>
                </button>
            </form>

            <div class="mt-12">
                <a href="/login" class="text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors font-urdu">لاگ ان پر واپس جائیں</a>
            </div>

            <div class="mt-10 text-slate-400 text-[10px] font-bold font-urdu opacity-60">
                © 2026 فکر اسلام۔ جملہ حقوق محفوظ ہیں۔
            </div>

            {/* Decorative elements */}
            <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-emerald-50 rounded-full blur-3xl -z-10"></div>
        </div>
    </div>

    <div id="success-container" class="hidden">
        <ResetSuccess />
    </div>
</div>

<script>
    const form = document.getElementById('forgot-password-form') as HTMLFormElement;
    const formContainer = document.getElementById('form-container');
    const successContainer = document.getElementById('success-container');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    const btnLoader = document.getElementById('btn-loader');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Loading state
        btnText?.classList.add('hidden');
        btnIcon?.classList.add('hidden');
        btnLoader?.classList.remove('hidden');
        submitBtn.disabled = true;

        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/auth/request-reset', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                // Show Success State
                formContainer?.classList.add('hidden');
                successContainer?.classList.remove('hidden');
                // @ts-ignore
                if (window.toast) window.toast.show("ری سیٹ لنک آپ کے ای میل پر بھیج دیا گیا ہے!", "success");
            } else {
                const errorText = await response.text();
                // @ts-ignore
                if (window.toast) window.toast.show(errorText || "سسٹم میں خرابی۔ دوبارہ کوشش کریں۔", "error");
                
                // Reset state
                btnText?.classList.remove('hidden');
                btnIcon?.classList.remove('hidden');
                btnLoader?.classList.add('hidden');
                submitBtn.disabled = false;
            }
        } catch (err) {
            // @ts-ignore
            if (window.toast) window.toast.show("سسٹم میں خرابی۔ دوبارہ کوشش کریں۔", "error");
            
            // Reset state
            btnText?.classList.remove('hidden');
            btnIcon?.classList.remove('hidden');
            btnLoader?.classList.add('hidden');
            submitBtn.disabled = false;
        }
    });
</script>
