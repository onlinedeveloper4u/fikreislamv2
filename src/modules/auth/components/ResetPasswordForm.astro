---
// src/modules/auth/components/ResetPasswordForm.astro
import Icon from '../../../components/shared/Icon.astro';
---

<div class="w-full max-w-md mx-auto p-4 animate-fade-in-up">
    <div class="bg-white rounded-[2.5rem] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] p-10 md:p-14 text-center relative overflow-hidden">
        {/* Logo Section */}
        <div class="mb-10 relative z-10 transition-transform duration-500 hover:scale-110">
            <div class="w-24 h-24 mx-auto rounded-full overflow-hidden mb-6 p-2 bg-slate-50">
                <img src="/logo.png" alt="فکر اسلام لوگو" class="w-full h-full object-contain" />
            </div>
            <div class="space-y-2">
                <h1 class="text-3xl font-black text-emerald-800 font-urdu leading-tight">پاس ورڈ ری سیٹ کریں</h1>
                <p class="text-slate-400 font-bold text-sm font-urdu opacity-80">براہ کرم اپنا نیا پاس ورڈ درج کریں</p>
            </div>
        </div>

        <form id="reset-password-form" class="space-y-6 relative z-10 text-right" dir="rtl">
            <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-500 mr-2 font-urdu">نیا پاس ورڈ</label>
                <div class="relative group">
                    <input 
                        type="password" 
                        id="new-password"
                        name="password"
                        required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-emerald-500 focus:bg-white shadow-sm transition-all outline-none font-bold text-slate-700 pr-14 pl-12"
                        placeholder="اپنا نیا پاس ورڈ لکھیں"
                    />
                    <div class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-emerald-600 transition-all">
                        <Icon name="lock" size={20} />
                    </div>
                    <button 
                        type="button"
                        class="toggle-password absolute left-5 top-1/2 -translate-y-1/2 text-emerald-600/50 hover:text-emerald-600 transition-all p-1"
                        data-target="new-password"
                    >
                        <Icon name="eye" size={18} class="show-pass" />
                        <Icon name="eye-off" size={18} class="hide-pass hidden" />
                    </button>
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-sm font-bold text-slate-500 mr-2 font-urdu">پاس ورڈ کی تصدیق</label>
                <div class="relative group">
                    <input 
                        type="password" 
                        id="confirm-password"
                        name="confirmPassword"
                        required
                        class="w-full px-6 py-4 rounded-2xl bg-slate-50 border border-slate-100 focus:border-emerald-500 focus:bg-white shadow-sm transition-all outline-none font-bold text-slate-700 pr-14 pl-12"
                        placeholder="دوبارہ پاس ورڈ لکھیں"
                    />
                    <div class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-emerald-600 transition-all">
                        <Icon name="lock" size={20} />
                    </div>
                    <button 
                        type="button"
                        class="toggle-password absolute left-5 top-1/2 -translate-y-1/2 text-emerald-600/50 hover:text-emerald-600 transition-all p-1"
                        data-target="confirm-password"
                    >
                        <Icon name="eye" size={18} class="show-pass" />
                        <Icon name="eye-off" size={18} class="hide-pass hidden" />
                    </button>
                </div>
            </div>

            <button 
                type="submit" 
                id="submit-btn"
                class="w-full py-5 rounded-2xl bg-[#2d4a27] text-white font-black text-xl shadow-lg hover:bg-[#1e331a] hover:-translate-y-1 active:scale-95 transition-all flex items-center justify-center gap-4 group"
            >
                <div id="btn-icon">
                    <Icon name="check" size={24} />
                </div>
                <span id="btn-text" class="font-urdu">پاس ورڈ ری سیٹ کریں</span>
                <div id="btn-loader" class="hidden">
                     <div class="w-6 h-6 border-4 border-white/30 border-t-white rounded-full animate-spin"></div>
                </div>
            </button>
        </form>

        <div class="mt-8">
            <a href="/login" class="text-sm font-bold text-slate-400 hover:text-emerald-600 transition-colors font-urdu inline-flex items-center gap-2">
                 لاگ ان پر واپس جائیں <Icon name="chevron-left" size={16} />
            </a>
        </div>

        {/* Decorative elements */}
        <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-emerald-50 rounded-full blur-3xl -z-10"></div>
    </div>
</div>

<script>
    // Password Toggle Logic
    const toggleBtns = document.querySelectorAll('.toggle-password');
    toggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const targetId = btn.getAttribute('data-target');
            if (!targetId) return;
            const input = document.getElementById(targetId) as HTMLInputElement;
            if (input) {
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';
                
                // Toggle icons
                btn.querySelector('.show-pass')?.classList.toggle('hidden', !isPassword);
                btn.querySelector('.hide-pass')?.classList.toggle('hidden', isPassword);
            }
        });
    });

    // Form Submission Logic
    const form = document.getElementById('reset-password-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const btnIcon = document.getElementById('btn-icon');
    const btnLoader = document.getElementById('btn-loader');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const newPass = (document.getElementById('new-password') as HTMLInputElement).value;
        const confirmPass = (document.getElementById('confirm-password') as HTMLInputElement).value;

        if (newPass !== confirmPass) {
             // @ts-ignore
            if (window.toast) window.toast.show("پاس ورڈ مماثل نہیں ہیں۔", "error");
            return;
        }

        const urlParams = new URLSearchParams(window.location.search);
        const token = urlParams.get('token');

        if (!token) {
            // @ts-ignore
            if (window.toast) window.toast.show("لنک غلط ہے یا اس کی مدت ختم ہو چکی ہے۔", "error");
            return;
        }

        // Loading state
        btnText?.classList.add('hidden');
        btnIcon?.classList.add('hidden');
        btnLoader?.classList.remove('hidden');
        submitBtn.disabled = true;

        const formData = new FormData();
        formData.append('token', token);
        formData.append('password', newPass);

        try {
            const response = await fetch('/api/auth/reset-password', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                // @ts-ignore
                if (window.toast) window.toast.show("پاس ورڈ کامیابی سے تبدیل ہو گیا!", "success");
                setTimeout(() => window.location.href = '/login', 1500);
            } else {
                const errorText = await response.text();
                // @ts-ignore
                if (window.toast) window.toast.show(errorText || "سسٹم میں خرابی۔ دوبارہ کوشش کریں۔", "error");
                
                // Reset state
                btnText?.classList.remove('hidden');
                btnIcon?.classList.remove('hidden');
                btnLoader?.classList.add('hidden');
                submitBtn.disabled = false;
            }
        } catch (err) {
            // @ts-ignore
            if (window.toast) window.toast.show("سسٹم میں خرابی۔ دوبارہ کوشش کریں۔", "error");
            btnText?.classList.remove('hidden');
            btnIcon?.classList.remove('hidden');
            btnLoader?.classList.add('hidden');
            submitBtn.disabled = false;
        }
    });
</script>
