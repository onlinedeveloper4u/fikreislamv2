---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../modules/home/components/HeroSection.astro';
import SearchSection from '../modules/home/components/SearchSection.astro';
import ContentGrid from '../modules/home/components/ContentGrid.astro';
import { getDb } from '../lib/db';
import type { ContentItem } from '../lib/types';

// Server-side fetch — all published audio content for the home page library
const db = await getDb();
const data = await db.collection('content')
  .find({ status: 'published', type: 'audio' })
  .sort({ published_at: -1 })
  .toArray();

// Map MongoDB _id to id for compatibility
let items: ContentItem[] = data.map((doc: any) => ({
  ...doc,
  id: doc._id.toString(),
})) as ContentItem[];
---

<BaseLayout title="فکر اسلام — آڈیو لائبریری" description="مختلف علماء کے بصیرت افروز خطبات، سلسلے اور قرآنی تلاوت سنیں۔">
  <HeroSection />
  <SearchSection />
  <div id="audio-library" class="container-app py-20">
    <ContentGrid
      items={items}
      title="آڈیو لائبریری"
      description="مختلف علماء کے بصیرت افروز خطبات، سلسلے اور قرآنی تلاوت سنیں۔"
    />
  </div>
</BaseLayout>
