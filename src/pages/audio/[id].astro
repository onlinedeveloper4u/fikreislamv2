---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import BentoGrid from '../../components/BentoGrid';
import { resolveMediaUrl } from '../../lib/media';
import { getSignedUrl, withSignedUrls } from '../../lib/storage';
import type { ContentItem } from '../../lib/types';

// Generate all static paths from Supabase at build time
export async function getStaticPaths() {
  const { supabase: sb } = await import('../../lib/supabase');
  const { data } = await sb
    .from('content')
    .select('id')
    .eq('status', 'approved');

  return (data || []).map((item: { id: string }) => ({
    params: { id: item.id },
  }));
}

// Get the dynamic id from the URL
const { id } = Astro.params;

// Fetch the specific content item
const { data: item, error: itemError } = await supabase
  .from('content')
  .select('id, title, description, author, type, language, tags, file_url, cover_image_url, published_at')
  .eq('id', id)
  .eq('status', 'approved')
  .single();

// If not found, redirect
if (itemError || !item) {
  return Astro.redirect('/audio');
}

const contentItem = item as ContentItem;
contentItem.cover_image_url = await getSignedUrl(contentItem.cover_image_url);

// Fetch related items
let relatedItems: ContentItem[] = [];
const { data: related } = await supabase
  .from('content')
  .select('id, title, description, author, type, language, tags, file_url, cover_image_url, published_at')
  .eq('status', 'approved')
  .eq('type', contentItem.type)
  .neq('id', contentItem.id)
  .order('published_at', { ascending: false })
  .limit(8);

relatedItems = (related as ContentItem[]) || [];
relatedItems = await withSignedUrls(relatedItems);

const playableUrl = resolveMediaUrl(contentItem.file_url);
---

<BaseLayout
  title={`${contentItem.title} — فکر اسلام`}
  description={contentItem.description || `${contentItem.title} — فکر اسلام پر سنیں`}
>
  <div class="container-app pt-28 pb-24">
    <!-- Detail Hero -->
    <div class="glass-card p-6 sm:p-8 lg:p-10 mb-12">
      <div class="flex flex-col lg:flex-row gap-8 items-start">
        <!-- Cover Art -->
        <div class="w-full lg:w-72 aspect-square rounded-2xl overflow-hidden shrink-0 relative group">
          {contentItem.cover_image_url ? (
            <img
              src={contentItem.cover_image_url}
              alt={contentItem.title}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-emerald-100 to-slate-100">
              <svg class="w-20 h-20 text-emerald-600/20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
              </svg>
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <!-- Type Badge -->
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[10px] font-bold text-emerald-600 bg-emerald-100/30 px-3 py-1 rounded-lg uppercase tracking-widest">
              {contentItem.type === 'audio' ? 'آڈیو' : contentItem.type === 'book' ? 'کتاب' : 'ویڈیو'}
            </span>
            {contentItem.language && (
              <span class="text-[10px] font-bold text-slate-900/40 glass px-3 py-1 rounded-lg uppercase tracking-widest">
                {contentItem.language}
              </span>
            )}
          </div>

          <h1 class="font-urdu text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4 tracking-tight">
            {contentItem.title}
          </h1>

          {contentItem.author && (
            <p class="text-emerald-700/60 text-lg font-medium flex items-center gap-2 mb-4">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {contentItem.author}
            </p>
          )}

          {contentItem.description && (
            <p class="text-slate-900/30 leading-relaxed max-w-2xl mb-6">
              {contentItem.description}
            </p>
          )}

          <!-- Tags -->
          {contentItem.tags && contentItem.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-8">
              {contentItem.tags.map((tag) => (
                <span class="text-[10px] font-bold text-emerald-600/60 bg-emerald-100/20 px-3 py-1.5 rounded-lg uppercase tracking-wider">
                  {tag}
                </span>
              ))}
            </div>
          )}

          <!-- Play Button (triggers global audio player) -->
          {playableUrl && (
            <button
              id="play-audio-btn"
              data-id={contentItem.id}
              data-title={contentItem.title}
              data-author={contentItem.author || ''}
              data-url={playableUrl}
              class="inline-flex items-center gap-3 px-8 py-4 rounded-2xl gradient-emerald-glow text-slate-900 font-bold text-base shadow-2xl shadow-emerald-500/30 hover:shadow-emerald-400/40 hover:scale-105 active:scale-95 transition-all cursor-pointer"
            >
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              ابھی سنیں
            </button>
          )}

          {contentItem.published_at && (
            <p class="text-slate-900/15 text-xs font-mono mt-6 flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {new Date(contentItem.published_at).toLocaleDateString('ur-PK', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          )}
        </div>
      </div>
    </div>

    <!-- Related Content -->
    {relatedItems.length > 0 && (
      <section>
        <BentoGrid
          client:visible
          items={relatedItems}
          title="مزید سنیں"
          description="اسی زمرے سے مزید مواد"
        />
      </section>
    )}
  </div>

  <!-- Script to wire the play button to the global audio store -->
  <script>
    import { audioStore } from '../../lib/audioStore';

    document.addEventListener('astro:page-load', () => {
      const btn = document.getElementById('play-audio-btn');
      if (!btn) return;

      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id') || '';
        const title = btn.getAttribute('data-title') || '';
        const author = btn.getAttribute('data-author') || undefined;
        const url = btn.getAttribute('data-url') || '';

        if (url) {
          audioStore.play({ id, title, author, url });
        }
      });
    });
  </script>
</BaseLayout>
