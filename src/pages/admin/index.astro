---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Icon from '../../components/shared/Icon.astro';
import { getDb } from '../../lib/db';

// Fetch stats on the server
const db = await getDb();

const [audioCount, speakerCount, categoryCount, pendingCount, recentData] = await Promise.all([
  db.collection('content').countDocuments(),
  db.collection('speakers').countDocuments(),
  db.collection('categories').countDocuments(),
  db.collection('content').countDocuments({ status: 'draft' }),
  db.collection('content').find().sort({ created_at: -1 }).limit(5).toArray()
]);

const stats = [
  { label: 'کل آڈیو', value: String(audioCount || 0), icon: 'music', color: 'emerald' },
  { label: 'کل مقررین', value: String(speakerCount || 0), icon: 'users', color: 'blue' },
  { label: 'کل اقسام', value: String(categoryCount || 0), icon: 'trending-up', color: 'purple' },
  { label: 'پینڈنگ مواد', value: String(pendingCount || 0), icon: 'upload', color: 'amber' },
];

// Map MongoDB _id to id for compatibility
const recentContent = recentData.map((doc: any) => ({
  ...doc,
  id: doc._id.toString(),
}));
---

<AdminLayout title="ایڈمن پورٹل — فکر اسلام" active="analytics">
  <div class="space-y-12 font-urdu pb-20">
    {/* Header Section */}
    <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-10">
      <div class="relative">
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/10 rounded-full blur-3xl"></div>
        <h1 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight leading-tight">اسلامی مواد کا انتظام</h1>
        <p class="text-slate-400 mt-4 text-xl font-bold max-w-xl opacity-80">خوش آمدید! آج آپ کیا تبدیل کرنا چاہیں گے؟ آپ کے پاس مکمل اختیار ہے۔</p>
      </div>
      
    </div>

    {/* Quick Stats Grid */}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="glass-premium p-8 rounded-[3rem] border border-white/40 shadow-premium group hover:border-emerald-500/20 transition-all duration-500 hover:-translate-y-2 relative overflow-hidden">
          <div class="absolute -top-10 -left-10 w-24 h-24 bg-white/5 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="flex items-center gap-6 relative z-10">
            <div class={`w-16 h-16 rounded-[1.5rem] flex items-center justify-center transition-all duration-500 group-hover:scale-110 shadow-sm ${
              stat.color === 'emerald' ? 'bg-emerald-500 text-white shadow-[0_10px_20px_-5px_rgba(16,185,129,0.3)]' :
              stat.color === 'blue' ? 'bg-blue-500 text-white shadow-[0_10px_20px_-5px_rgba(59,130,246,0.3)]' :
              stat.color === 'purple' ? 'bg-purple-500 text-white shadow-[0_10px_20px_-5px_rgba(168,85,247,0.3)]' :
              'bg-amber-500 text-white shadow-[0_10px_20px_-5px_rgba(245,158,11,0.3)]'
            }`}>
              <Icon name={stat.icon} size={32} />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-slate-400 text-[10px] font-black uppercase tracking-[0.2em] mb-1 opacity-70">{stat.label}</p>
              <p class="text-4xl font-black text-slate-900 tracking-tighter">{stat.value}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Recent Activity Section */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
        <div class="lg:col-span-8 space-y-8">
            <div class="flex items-center justify-between px-4">
                <h2 class="text-3xl font-black text-slate-800 flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center">
                        <Icon name="music" size={24} class="text-emerald-500" />
                    </div>
                    حالیہ اپ لوڈز
                </h2>
                <a href="/admin/content" class="text-emerald-500 font-black hover:text-emerald-600 transition-colors flex items-center gap-2 text-sm uppercase tracking-widest">
                    پوری ہسٹری دیکھیں
                    <Icon name="chevron-left" size={20} />
                </a>
            </div>

            <div class="glass-premium rounded-[3.5rem] border border-white/40 shadow-premium overflow-hidden">
                <div class="divide-y divide-slate-50">
                    {recentContent.length === 0 ? (
                        <div class="py-32 flex flex-col items-center justify-center text-center space-y-4 opacity-30">
                            <Icon name="music" size={64} class="text-slate-200" />
                            <p class="text-2xl font-black text-slate-400">کوئی مواد ریکارڈ نہیں پایا گیا</p>
                        </div>
                    ) : recentContent.map((item: any) => (
                        <div class="p-8 flex items-center justify-between group hover:bg-white/40 transition-all duration-500">
                            <div class="flex items-center gap-8">
                                <div class="w-20 h-20 rounded-[1.75rem] bg-white shadow-premium overflow-hidden flex items-center justify-center border border-white p-1 group-hover:rotate-3 transition-all duration-500">
                                    {item.cover_image_url ? (
                                        <img src={item.cover_image_url} alt="" class="w-full h-full object-cover rounded-[1.25rem]" />
                                    ) : (
                                        <div class="w-full h-full bg-slate-50 rounded-[1.25rem] flex items-center justify-center">
                                            <Icon name="music" size={32} class="text-slate-200" />
                                        </div>
                                    )}
                                </div>
                                <div class="space-y-2">
                                    <h4 class="font-black text-slate-900 text-2xl group-hover:text-emerald-600 transition-colors leading-tight">{item.title}</h4>
                                    <div class="flex items-center gap-6 text-sm text-slate-400 font-black">
                                        <span class="flex items-center gap-2">
                                            <Icon name="user" size={16} class="text-emerald-500" />
                                            {item.speaker || 'عام مقرر'}
                                        </span>
                                        <span class="flex items-center gap-2 opacity-50">
                                            <Icon name="calendar" size={16} />
                                            {new Date(item.created_at).toLocaleDateString('ur-PK')}
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-5">
                                <span class={`px-5 py-2 rounded-[1rem] text-[9px] font-black uppercase tracking-[0.2em] shadow-sm ${
                                    item.status === 'published' 
                                    ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' 
                                    : 'bg-amber-50 text-amber-600 border border-amber-100'
                                }`}>
                                    {item.status === 'published' ? 'لائیو' : 'ڈرافٹ'}
                                </span>
                                <a href={`/admin/content?edit=${item.id}`} class="w-12 h-12 flex items-center justify-center bg-white rounded-2xl text-slate-300 hover:text-emerald-500 hover:shadow-premium hover:-translate-y-1 transition-all border border-slate-100">
                                    <Icon name="chevron-left" size={24} />
                                </a>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        {/* Sidebar Mini-Stats/Activity */}
        <div class="lg:col-span-4 space-y-10">
            <h2 class="text-3xl font-black text-slate-800 px-4 flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-blue-500/10 flex items-center justify-center">
                    <Icon name="trending-up" size={24} class="text-blue-500" />
                </div>
                سرگرمی
            </h2>
            
            <div class="bg-slate-900 p-10 rounded-[3rem] text-white shadow-premium relative overflow-hidden group">
                <div class="absolute -top-20 -right-20 w-48 h-48 bg-emerald-500/10 rounded-full blur-3xl group-hover:bg-emerald-500/20 transition-all duration-700"></div>
                <div class="relative z-10 space-y-6">
                    <p class="text-emerald-400 font-black uppercase tracking-[0.3em] text-[10px]">کلاؤڈ انفراسٹرکچر</p>
                    <h3 class="text-3xl font-black leading-tight">سسٹم مکمل طور پر محفوظ ہے</h3>
                    <p class="text-slate-400 font-bold leading-relaxed opacity-80">
                        فکر اسلام کا ڈیٹا بینک جدید ترین انکرپشن اور سیکیورٹی پروٹوکولز کے تحت محفوظ ہے۔
                    </p>
                    <div class="flex items-center gap-4 py-4 px-6 bg-white/5 rounded-2xl border border-white/10 group-hover:border-emerald-500/30 transition-all">
                        <div class="w-3 h-3 rounded-full bg-emerald-500 shadow-glow-emerald animate-pulse" />
                        <span class="text-sm font-black text-emerald-100 tracking-wide uppercase">فائر والز فعال ہیں</span>
                    </div>
                </div>
            </div>

            <div class="glass-premium p-10 rounded-[3rem] text-slate-800 shadow-premium relative overflow-hidden group border border-white/40">
                <div class="relative z-10 space-y-6">
                    <p class="text-indigo-500 font-black uppercase tracking-[0.3em] text-[10px]">ترقی کے اعداد و شمار</p>
                    <h3 class="text-3xl font-black text-slate-900">مواد کی ترقی</h3>
                    <p class="text-slate-400 font-bold leading-relaxed">
                        پچھلے 30 دنوں میں 15% زائد اضافہ ریکارڈ کیا گیا ہے۔ یہ آپ کی محنت کا نتیجہ ہے۔
                    </p>
                    <div class="space-y-4 pt-4">
                        <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                            <div class="bg-indigo-500 rounded-full h-full w-[72%] shadow-glow-indigo animate-pulse" />
                        </div>
                        <div class="flex justify-between items-center text-[10px] font-black uppercase tracking-widest text-slate-400 px-1">
                            <span>ماہانہ ہدف</span>
                            <span class="text-indigo-600">72% مکمل</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </div>
</AdminLayout>
