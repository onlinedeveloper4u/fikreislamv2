---
import { ClientRouter } from 'astro:transitions';
import Navbar from '../components/shared/Navbar.astro';
import Footer from '../components/shared/Footer.astro';
import Toast from '../components/shared/Toast.astro';
import GlobalAudioPlayer from '../modules/audio/components/GlobalAudioPlayer.astro';
import '../styles/main.css';

interface Props {
  title?: string;
  description?: string;
  showNav?: boolean;
  showFooter?: boolean;
}

const {
  title = 'فکر اسلام — مستند اسلامی مواد',
  description = 'مستند اسلامی کتب، خطبات اور ویڈیوز کا ایک جامع ذخیرہ — قابل اعتماد علماء سے',
  showNav = true,
  showFooter = true,
} = Astro.props;
---

<!doctype html>
<html lang="ur" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#10b981" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="bg-slate-50 text-slate-900/80 antialiased font-urdu">
    {/* Common Toast component */}
    <Toast />

    {/* Navbar */}
    {showNav && <Navbar />}

    {/* Page Content */}
    <main class={`min-h-screen ${showNav ? 'pt-20' : ''}`}>
      <slot />
    </main>

    {/* Footer */}
    {showFooter && <Footer />}

    {/* Persistent Audio Player */}
    <GlobalAudioPlayer transition:persist />
  </body>
</html>
