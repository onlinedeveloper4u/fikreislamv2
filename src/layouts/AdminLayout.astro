---
import { ClientRouter } from 'astro:transitions';
import AdminSidebar from '../modules/admin/components/AdminSidebar.astro';
import Icon from '../components/shared/Icon.astro';
import Toast from '../components/shared/Toast.astro';
import '../styles/main.css';

interface Props {
  title?: string;
  active?: string;
}

const { title = 'ایڈمن پینل — فکر اسلام', active = 'dashboard' } = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="ur" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#121212" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
    <ClientRouter />
    <style is:global>
      html, body {
        overflow-x: hidden;
        position: relative;
        max-width: 100vw;
      }
      body {
        padding-bottom: 0 !important;
      }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased font-urdu min-h-screen overflow-x-hidden">
    <Toast />
    
    <!-- Sidebar Overlay (Mobile) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-90 hidden opacity-0 transition-opacity duration-500"></div>

    <!-- Mobile Header -->
    <header class="lg:hidden fixed top-0 right-0 left-0 glass-premium border-b border-white/40 z-40 p-5 flex items-center justify-between shadow-premium">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 flex items-center justify-center overflow-hidden">
          <img src="/logo.png" alt="فکر اسلام لوگو" class="w-full h-full object-contain" />
        </div>
        <div>
          <h2 class="text-xl font-black text-slate-900 leading-tight">فکر اسلام</h2>
          <span class="text-[8px] font-black text-emerald-600 uppercase tracking-widest mt-1 opacity-80">ایڈمن موبائل</span>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <a 
          href="/api/auth/signout" 
          class="px-4 h-12 flex items-center justify-center gap-2 bg-red-50 rounded-[1.25rem] shadow-sm text-red-500 hover:bg-red-500 hover:text-white transition-all border border-red-100 font-urdu font-black text-sm"
          title="لاگ آؤٹ"
        >
          <Icon name="logout" size={18} />
          <span>لاگ آؤٹ</span>
        </a>
        <button 
          id="open-sidebar" 
          class="w-12 h-12 flex items-center justify-center bg-white rounded-[1.25rem] shadow-sm text-slate-400 hover:text-emerald-500 transition-all border border-slate-100"
        >
          <Icon name="menu" size={24} />
        </button>
      </div>
    </header>

    <AdminSidebar active={active} transition:persist />
    
    <div id="admin-main-wrapper" class="flex-1 mr-0 lg:mr-80 flex flex-col min-h-screen relative">
      <main class="p-6 lg:p-12 relative flex-1 transition-all duration-700" transition:animate="fade">
      <!-- Background Accents -->
      <div class="fixed top-0 left-0 w-full h-full pointer-events-none -z-10 overflow-hidden">
        <div class="absolute -top-1/4 -left-1/4 w-1/2 h-1/2 bg-emerald-500/5 rounded-full blur-[120px] animate-blob"></div>
        <div class="absolute -bottom-1/4 -right-1/4 w-1/2 h-1/2 bg-blue-500/5 rounded-full blur-[120px] animate-blob animation-delay-4000"></div>
      </div>

      <div class="max-w-[1600px] mx-auto">
        <slot />
      </div>
    </main>
    </div>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        const sidebar = document.getElementById('admin-sidebar');
        const overlay = document.getElementById('sidebar-overlay');
        const openBtn = document.getElementById('open-sidebar');
        const closeBtn = document.getElementById('close-sidebar');

        // Global Scroll Lock Helper
        window.toggleBodyScroll = (lock) => {
          document.body.style.overflow = lock ? 'hidden' : '';
          const wrapper = document.getElementById('admin-main-wrapper');
          if (wrapper) {
            wrapper.style.zIndex = lock ? '9001' : '';
          }
           // Handle the case where the sidebar might also be open
          if (!lock && sidebar && !sidebar.classList.contains('translate-x-full') && window.innerWidth < 1024) {
            document.body.style.overflow = 'hidden';
          }
        };

        const toggleSidebar = (show) => {
          if (show) {
            sidebar?.classList.remove('invisible');
            sidebar?.classList.remove('translate-x-full');
            overlay?.classList.remove('hidden');
            setTimeout(() => overlay?.classList.remove('opacity-0'), 10);
            window.toggleBodyScroll(true);
          } else {
            sidebar?.classList.add('translate-x-full');
            overlay?.classList.add('opacity-0');
            setTimeout(() => {
              sidebar?.classList.add('invisible');
              overlay?.classList.add('hidden');
              window.toggleBodyScroll(false);
            }, 300);
          }
        };

        openBtn?.addEventListener('click', () => toggleSidebar(true));
        closeBtn?.addEventListener('click', () => toggleSidebar(false));
        overlay?.addEventListener('click', () => toggleSidebar(false));

        // Close on link click (mobile)
        sidebar?.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            if (window.innerWidth < 1024) toggleSidebar(false);
          });
        });
      });
    </script>
  </body>
</html>
